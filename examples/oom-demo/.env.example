# Скопируй в .env и заполни нужные значения.
# Пустые переменные игнорируются — notifier не создаётся.

# Slack webhook URL (опционально)
SLACK_WEBHOOK_URL=

# Telegram bot token и chat ID (опционально, нужны оба)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Настройки сервиса
SERVICE_NAME=oom-demo
PORT=8080
DUMP_DIR=/tmp/dumps

# POLL_INTERVAL — базовый интервал polling (default в demo: 500ms).
# В продакшн сервисах не задавай — там дефолт пакета (5s) более подходящий.
POLL_INTERVAL=500ms

# GOMEMLIMIT передаётся в docker run / k8s deployment напрямую
# GOMEMLIMIT=200MiB
